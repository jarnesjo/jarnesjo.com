---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
  type?: string
  date?: string
  author?: string
  category?: string
  tags?: string[]
  image?: {src: string; alt: string; width?: number; height?: number}
}

const defaultMeta = {
  title: 'Nicklas Jarnesjö',
  description: 'Writing about web development, side projects and things I learn along the way',
  siteUrl: 'https://jarnesjo.com',
  twitterHandle: '@jarnesjo',
  image: {
    src: 'https://jarnesjo.com/static/images/default-sharing.png',
    alt: 'jarnesjo.com logo on dark background',
    width: 1200,
    height: 630
  }
}

const props = Astro.props
const title = props.title || defaultMeta.title
const description = props.description || defaultMeta.description
const type = props.type || 'website'
const image = props.image || defaultMeta.image
const url = `${defaultMeta.siteUrl}${Astro.url.pathname}`

const menuItems = [
  {title: 'Home', href: '/'},
  {title: 'Writing', href: '/writing'},
  {title: 'About', href: '/about'}
]
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link href="/static/favicons/favicon.ico" rel="shortcut icon" />

    <link rel="canonical" href={url} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="image" content={image.src} />

    <!-- Open Graph -->
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:type" content={type} />
    <meta property="og:image" content={image.src} />
    <meta property="og:image:alt" content={image.alt} />
    <meta property="og:image:width" content={String(image.width || 1200)} />
    <meta property="og:image:height" content={String(image.height || 630)} />

    {type === 'article' && props.date && (
      <meta property="article:published_time" content={new Date(props.date).toISOString()} />
    )}
    {type === 'article' && (
      <meta property="article:author" content={props.author || 'Nicklas Jarnesjö'} />
    )}
    {type === 'article' && props.category && (
      <meta property="article:section" content={props.category} />
    )}
    {type === 'article' && props.tags?.map(tag => (
      <meta property="article:tag" content={tag} />
    ))}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={defaultMeta.twitterHandle} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image.src} />
    <meta name="twitter:creator" content={defaultMeta.twitterHandle} />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="Nicklas Jarnesjö" href={`${defaultMeta.siteUrl}/feed.xml`} />

    <!-- JSON-LD -->
    {type === 'article' && props.date && (
      <script type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: title,
        description,
        datePublished: new Date(props.date).toISOString(),
        author: {'@type': 'Person', name: props.author || 'Nicklas Jarnesjö', url: defaultMeta.siteUrl},
        publisher: {'@type': 'Person', name: 'Nicklas Jarnesjö', url: defaultMeta.siteUrl},
        url,
        ...(image && {image: {'@type': 'ImageObject', url: image.src}}),
        ...(props.category && {articleSection: props.category}),
        ...(props.tags && {keywords: props.tags.join(', ')})
      })} />
    )}

    <!-- Dark mode: prevent flash -->
    <script is:inline>
      const theme = localStorage.getItem('theme') || 'system'
      const isDark = theme === 'dark' || (theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches)
      if (isDark) document.documentElement.classList.add('dark')
    </script>
  </head>
  <body class="bg-white dark:bg-gray-900 text-gray-900 dark:text-white transition-colors duration-200">
    <div class="max-w-4xl mx-auto pt-8 px-4 sm:px-8">
      <a class="sr-only" href="#main">skip to main content</a>
      <header class="flex justify-between items-center text-gray-700 dark:text-gray-200 transition-colors duration-200">
        <div>
          <a class="flex items-center" href="/">
            <div class="rounded-full ring-1 ring-gray-300 dark:ring-gray-100 overflow-hidden w-10 h-10 sm:w-12 sm:h-12 flex-shrink-0">
              <img
                src="/static/images/avatar.jpg"
                alt="Avatar of Nicklas Jarnesjö"
                width="400"
                height="400"
                loading="lazy"
                class="rounded-full"
              />
            </div>
            <div class="ml-4 font-semibold">Nicklas Jarnesjö</div>
          </a>
        </div>

        <nav class="flex md:space-x-10">
          <ul class="space-x-10 font-semibold items-center hidden md:flex">
            {menuItems.map(({title, href}) => (
              <li>
                <a class="hover:text-gray-900 dark:hover:text-white neon" href={href}>{title}</a>
              </li>
            ))}
          </ul>

          <!-- Dark mode toggle (system → light → dark) -->
          <button
            id="theme-toggle"
            class="rounded-full p-2 w-10 h-10 text-red-600 dark:text-gray-200 hover:text-red-700 bg-red-100 hover:bg-red-200 dark:bg-transparent focus:outline-none dark:hover:bg-gray-800 dark:ring-2 dark:ring-gray-800 dark:hover:ring-gray-700 transition-all duration-200"
            aria-label="Toggle theme"
          >
            <!-- Sun (light) -->
            <svg id="icon-light" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
            <!-- Moon (dark) -->
            <svg id="icon-dark" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
            <!-- Monitor (system) -->
            <svg id="icon-system" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </button>

          <!-- Mobile menu button -->
          <button
            id="mobile-menu-btn"
            class="p-2 rounded-full md:hidden ml-6 bg-gray-200 dark:bg-gray-700 hover:bg-gray-400 dark:hover:bg-gray-800 dark:ring-2 dark:ring-gray-800 dark:hover:ring-gray-700 hover:text-white transition-all duration-200 focus:outline-none"
            aria-label="Open mobile menu"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>

          <!-- Mobile menu overlay -->
          <div id="mobile-menu" class="bg-black bg-opacity-90 text-white fixed inset-0 z-10 hidden">
            <button id="mobile-menu-close" class="absolute right-4 top-8 p-2 bg-black rounded-full">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
            <ul class="flex items-center justify-center h-full flex-col text-3xl space-y-8">
              {menuItems.map(({title, href}) => (
                <li><a href={href}>{title}</a></li>
              ))}
            </ul>
          </div>
        </nav>
      </header>

      <main id="main" class="pb-10 max-w-2xl mx-auto">
        <slot />
      </main>

      <footer class="text-gray-500 dark:text-gray-300 text-center mt-10 pb-8 md:mt-16 flex flex-row flex-wrap justify-center">
        {menuItems.map(item => (
          <a href={item.href} class="p-4 dark:hover:text-gray-400">{item.title}</a>
        ))}
        <a href="/uses" class="p-4 dark:hover:text-gray-400">Uses</a>
        <a class="p-4 dark:hover:text-gray-400" rel="noopener" href="https://x.com/jarnesjo">X</a>
        <a href="/feed.xml" class="p-4 dark:hover:text-gray-400">RSS</a>
      </footer>
    </div>

    <script>
      // Three-way theme toggle: system → light → dark
      const themes = ['system', 'light', 'dark'] as const
      let switchSound: HTMLAudioElement | null = null
      let currentTheme = localStorage.getItem('theme') || 'system'

      function applyTheme(theme: string) {
        const isDark = theme === 'dark' || (theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches)
        document.documentElement.classList.toggle('dark', isDark)

        document.getElementById('icon-light')!.classList.toggle('hidden', theme !== 'light')
        document.getElementById('icon-dark')!.classList.toggle('hidden', theme !== 'dark')
        document.getElementById('icon-system')!.classList.toggle('hidden', theme !== 'system')
      }

      applyTheme(currentTheme)

      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        if (!switchSound) {
          switchSound = new Audio('/static/sounds/switch.mp3')
        }
        switchSound.currentTime = 0
        switchSound.play()

        const idx = themes.indexOf(currentTheme as typeof themes[number])
        currentTheme = themes[(idx + 1) % themes.length]
        localStorage.setItem('theme', currentTheme)
        applyTheme(currentTheme)
      })

      // Listen for system theme changes when in system mode
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
        if ((localStorage.getItem('theme') || 'system') === 'system') {
          applyTheme('system')
        }
      })

      // Mobile menu
      document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
        document.getElementById('mobile-menu')?.classList.remove('hidden')
      })
      document.getElementById('mobile-menu-close')?.addEventListener('click', () => {
        document.getElementById('mobile-menu')?.classList.add('hidden')
      })

      // Neon flicker effect
      const animatedElements = document.querySelectorAll('.js-darkmode-flicker')
      animatedElements.forEach(el => {
        const text = el.textContent?.trim() || ''
        const count = parseInt(el.getAttribute('data-flicker-chars') || '1')
        const chars = text.split('')
        const excluded = [' ', '-', ',', ';', ':', '(', ')', "'", '.']
        const usedIndexes: number[] = []
        let i = 0

        while (i < count) {
          const idx = Math.floor(Math.random() * chars.length)
          if (!usedIndexes.includes(idx) && !excluded.includes(chars[idx])) {
            chars[idx] = `<span class="flicker"><span class="tipping">${chars[idx]}</span></span>`
            usedIndexes.push(idx)
            i++
          }
        }

        el.innerHTML = chars
          .join('')
          .split(/((?!\sclass)\s)/gm)
          .map(word => word === ' ' ? word : `<span class="word-no-wrap">${word}</span>`)
          .join('')
      })
    </script>

    {import.meta.env.PROD && (
      <>
        <script is:inline src="https://puls.wrlabs.se/?js" data-site="jarnesjo.com" data-outbound data-auto-events defer></script>
        <img
          src={`https://puls.wrlabs.se/?pixel&s=jarnesjo.com&p=${Astro.url.pathname}`}
          alt="" width="1" height="1"
          style="position:absolute;opacity:0"
        />
      </>
    )}
  </body>
</html>
