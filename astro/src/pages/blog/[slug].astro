---
import Layout from '../../layouts/Default.astro'
import Image from '../../components/mdx/Image.astro'
import Video from '../../components/mdx/Video.astro'
import {getCollection, render} from 'astro:content'

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({data}) => data.published !== false)
  return posts.map(post => ({
    params: {slug: post.data.slug},
    props: {post}
  }))
}

const {post} = Astro.props
const {title, description, date, category, tags, author, image} = post.data
const {Content} = await render(post)

const siteUrl = 'https://jarnesjo.com'

const formatted = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
}).format(date)

const metaImage = image ? {...image, src: `${siteUrl}${image.src}`} : undefined
---

<Layout
  title={title}
  description={description}
  type="article"
  date={date.toISOString()}
  author={author}
  category={category}
  tags={tags}
  image={metaImage}
>
  <article id="single-article">
    <header class="py-12 md:py-16 text-center">
      <h1
        class="text-5xl tracking-tight font-bold mb-4 leading-snug lg:-mx-20 js-darkmode-flicker"
        data-flicker-chars={title.length > 35 ? '2' : '1'}
      >
        {title}
      </h1>
      <div class="text-gray-500 dark:text-gray-400 flex justify-center space-x-2 uppercase">
        <time datetime={date.toISOString()}>{formatted}</time>
        <span>&bull;</span>
        <a href={`/category/${category}`} class="uppercase">{category}</a>
      </div>
    </header>

    <div class="prose md:prose-lg lg:prose-xl dark:prose-dark mx-auto">
      <Content components={{Image, Video}} />
    </div>

    <div class="text-center my-10 py-8 text-gray-600 bg-gray-200 dark:bg-gray-800 dark:text-gray-400 transition-colors duration-200 rounded-md">
      <div class="pb-2">Discuss this post on Twitter</div>
      <div class="space-x-2">
        <a
          class="text-gray-600 dark:text-gray-300 hover:text-gray-700 transition-colors"
          rel="noopener"
          href={`http://twitter.com/share?text=Hi @jarnesjo&url=${encodeURIComponent(`${siteUrl}/blog/${post.data.slug}`)}`}
        >
          With me
        </a>
        <span>&bull;</span>
        <a
          class="text-gray-600 dark:text-gray-300 hover:text-gray-700"
          rel="noopener"
          href={`https://mobile.twitter.com/search?q=${encodeURIComponent(`${siteUrl}/blog/${post.data.slug}`)}`}
        >
          With others
        </a>
      </div>
    </div>

    <div class="md:flex md:space-x-6 text-gray-500 dark:text-gray-300 uppercase text-sm mt-10 py-6 md:px-2 border-t border-b border-gray-200 dark:border-gray-700 transition-colors duration-200">
      <div class="flex flex-col">
        <span class="text-xs uppercase text-gray-500 dark:text-gray-400 hover:text-gray-700 transition-colors">
          Category
        </span>
        <a
          href={`/category/${category}`}
          class="uppercase font-medium transition-colors hover:text-red-600"
          title="Category"
        >
          {category}
        </a>
      </div>
      {tags && (
        <div class="flex flex-col mt-3 md:mt-0">
          <span class="text-xs uppercase text-gray-500 dark:text-gray-400">Tags</span>
          <ul class="flex space-x-3">
            {tags.map(tag => (
              <li class="flex-shrink-0">
                <a
                  href={`/tag/${tag}`}
                  class="uppercase transition-colors hover:text-red-600"
                >
                  #{tag}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </article>
</Layout>
